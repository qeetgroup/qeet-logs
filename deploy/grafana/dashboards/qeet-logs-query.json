  "description": "RED (Rate, Errors, Duration) dashboard for the Qeet Logs query API, driven by the qeet_logs_http_* self-metrics on :8100/metrics. Thresholds encode the SLO targets from docs/slo-sli.md (p95 < 2 s, p99 < 8 s, availability >= 99.9%).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 11,
      "type": "row",
      "title": "RED overview \u2014 SLO scorecard",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Request rate",
      "description": "Total query-API request throughput.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(rate(qeet_logs_http_requests_total{route=~\"$route\"}[$__rate_interval]))",
          "editorMode": "code",
          "instant": false,
          "range": true,
          "format": "time_series"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0
              },
              {
                "color": "green",
                "value": 0
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Error ratio (5xx)",
      "description": "Fraction of responses with a 5xx status. Availability SLO is >= 99.9% (error ratio < 0.1%).",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(rate(qeet_logs_http_requests_total{status=~\"5..\",route=~\"$route\"}[$__rate_interval])) / clamp_min(sum(rate(qeet_logs_http_requests_total{route=~\"$route\"}[$__rate_interval])), 1e-9)",
          "editorMode": "code",
          "instant": false,
          "range": true,
          "format": "time_series"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.001
              },
              {
                "color": "red",
                "value": 0.01
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "decimals": 3
        },
        "overrides": []
      }
    },
    {
      "id": 14,
