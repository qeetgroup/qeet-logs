          "expr": "sum(rate(qeet_logs_http_requests_total{status!~\"5..\",route=~\"$route\"}[$__rate_interval])) / clamp_min(sum(rate(qeet_logs_http_requests_total{route=~\"$route\"}[$__rate_interval])), 1e-9)",
