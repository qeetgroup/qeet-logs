{
  "info": {
    "_postman_id": "8f3b6e10-7a3f-4d9c-9a55-qeetlogs00001",
    "name": "Qeet Logs API (v1)",
    "description": "Privacy-first, multi-tenant observability platform — logs, metrics, and traces.\n\nAuth: set the collection variable `apiKey` to a Qeet Logs key (e.g. `ql_live_…`); it is sent as the `X-Qeet-Api-Key` header on every request. Admin routes also accept a Qeet ID Bearer JWT.\n\nTwo hosts:\n- `apiBaseUrl` — query & admin API (default http://localhost:8100)\n- `ingestBaseUrl` — ingest gateway (default http://localhost:8101)\n\nRBAC scopes: `logs:ingest` (write), `logs:read`/`logs:query` (read), `logs:admin` (admin). Ingest requests target `{{ingestBaseUrl}}`; everything else targets `{{apiBaseUrl}}`.\n\nMirrors `api/openapi/*.yaml` — keep the two in sync when routes change.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "X-Qeet-Api-Key", "type": "string" },
      { "key": "value", "value": "{{apiKey}}", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "variable": [
    { "key": "apiBaseUrl", "value": "http://localhost:8100" },
    { "key": "ingestBaseUrl", "value": "http://localhost:8101" },
    { "key": "apiKey", "value": "ql_live_replace_me" },
    { "key": "apiKeyId", "value": "" },
    { "key": "alertRuleId", "value": "" },
    { "key": "erasureId", "value": "" },
    { "key": "dashboardId", "value": "" },
    { "key": "savedSearchId", "value": "" },
    { "key": "shareToken", "value": "" },
    { "key": "dlqId", "value": "" },
    { "key": "traceId", "value": "4bf92f3577b34da6a3ce929d0e0e4736" },
    { "key": "incidentId", "value": "" }
  ],
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('status is not a server error', function () {",
          "  pm.expect(pm.response.code).to.be.below(500);",
          "});",
          "pm.test('responds within 5s', function () {",
          "  pm.expect(pm.response.responseTime).to.be.below(5000);",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Health check — GET /healthz",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{apiBaseUrl}}/healthz", "host": ["{{apiBaseUrl}}"], "path": ["healthz"] },
            "description": "Liveness probe. Public."
          }
        },
        {
          "name": "Readiness — GET /readyz",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{apiBaseUrl}}/readyz", "host": ["{{apiBaseUrl}}"], "path": ["readyz"] },
            "description": "Readiness probe — checks Postgres, Redis, ClickHouse, NATS. 200 when all reachable, 503 otherwise."
          }
        },
        {
          "name": "Version — GET /version",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{apiBaseUrl}}/version", "host": ["{{apiBaseUrl}}"], "path": ["version"] },
            "description": "Binary version string. Public."
          }
        }
      ]
    },
    {
      "name": "Ingest",
      "item": [
        {
          "name": "Ingest single log — POST /v1/ingest",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{ingestBaseUrl}}/v1/ingest", "host": ["{{ingestBaseUrl}}"], "path": ["v1", "ingest"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"service\": \"payments\",\n  \"level\": \"error\",\n  \"message\": \"stripe webhook signature mismatch\",\n  \"trace_id\": \"{{traceId}}\",\n  \"environment\": \"production\",\n  \"request_id\": \"req_xyz\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Accepts a single flat JSON object. `service` + `message` are the meaningful fields; recognised keys are promoted to typed columns, extras go to the `body` JSON column. Requires `logs:ingest`. → 202 {accepted, dropped, errors}."
          }
        },
        {
          "name": "Ingest batch (NDJSON) — POST /v1/ingest/batch",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-ndjson" }],
            "url": { "raw": "{{ingestBaseUrl}}/v1/ingest/batch", "host": ["{{ingestBaseUrl}}"], "path": ["v1", "ingest", "batch"] },
            "body": {
              "mode": "raw",
              "raw": "{\"service\":\"api\",\"level\":\"info\",\"message\":\"request processed\"}\n{\"service\":\"api\",\"level\":\"warn\",\"message\":\"slow query\",\"duration_ms\":850}",
              "options": { "raw": { "language": "text" } }
            },
            "description": "Newline-delimited JSON — one record per line. Per-line parse errors are counted in `errors` but don't abort the batch. Requires `logs:ingest`."
          }
        },
        {
          "name": "Ingest GELF — POST /v1/ingest/gelf",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{ingestBaseUrl}}/v1/ingest/gelf", "host": ["{{ingestBaseUrl}}"], "path": ["v1", "ingest", "gelf"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"version\": \"1.1\",\n  \"host\": \"web-1\",\n  \"short_message\": \"user login failed\",\n  \"level\": 3,\n  \"_service\": \"auth\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Graylog Extended Log Format (GELF) JSON. `_`-prefixed fields become attributes. Requires `logs:ingest`."
          }
        },
        {
          "name": "Ingest syslog (RFC 5424) — POST /v1/ingest/syslog",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "text/plain" }],
            "url": { "raw": "{{ingestBaseUrl}}/v1/ingest/syslog", "host": ["{{ingestBaseUrl}}"], "path": ["v1", "ingest", "syslog"] },
            "body": {
              "mode": "raw",
              "raw": "<34>1 2024-01-15T10:00:00Z host authd - - - Authentication failure",
              "options": { "raw": { "language": "text" } }
            },
            "description": "Raw RFC 5424 syslog line. Requires `logs:ingest`."
          }
        },
        {
          "name": "OTLP logs — POST /v1/logs",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{ingestBaseUrl}}/v1/logs", "host": ["{{ingestBaseUrl}}"], "path": ["v1", "logs"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resourceLogs\": [\n    {\n      \"resource\": { \"attributes\": [{ \"key\": \"service.name\", \"value\": { \"stringValue\": \"checkout\" } }] },\n      \"scopeLogs\": [{ \"logRecords\": [{ \"severityText\": \"ERROR\", \"body\": { \"stringValue\": \"payment declined\" } }] }]\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "OTLP/HTTP `ExportLogsServiceRequest` (JSON or protobuf). Also available on :4318. Requires `logs:ingest`."
          }
        },
        {
          "name": "OTLP metrics — POST /v1/metrics",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{ingestBaseUrl}}/v1/metrics", "host": ["{{ingestBaseUrl}}"], "path": ["v1", "metrics"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"metric_name\": \"http_requests_total\",\n  \"metric_type\": \"sum\",\n  \"service\": \"api\",\n  \"value\": 42\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "OTLP/HTTP `ExportMetricsServiceRequest`, or a single MetricIngestRecord as shown. Requires `logs:ingest`."
          }
        },
        {
          "name": "OTLP traces — POST /v1/traces",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{ingestBaseUrl}}/v1/traces", "host": ["{{ingestBaseUrl}}"], "path": ["v1", "traces"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trace_id\": \"{{traceId}}\",\n  \"span_id\": \"00f067aa0ba902b7\",\n  \"service\": \"checkout\",\n  \"name\": \"POST /charge\",\n  \"start_time_unix_nano\": 1705312800000000000,\n  \"end_time_unix_nano\": 1705312800120000000\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "OTLP/HTTP `ExportTraceServiceRequest`, or a single SpanIngestRecord as shown. Requires `logs:ingest`."
          }
        },
        {
          "name": "Prometheus remote_write — POST /api/v1/write",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-protobuf" }, { "key": "Content-Encoding", "value": "snappy" }],
            "url": { "raw": "{{ingestBaseUrl}}/api/v1/write", "host": ["{{ingestBaseUrl}}"], "path": ["api", "v1", "write"] },
            "body": { "mode": "raw", "raw": "" },
            "description": "Prometheus remote_write — Snappy-compressed protobuf body (not representable as raw text here; point a Prometheus `remote_write` at this URL). Requires `logs:ingest`. → 204."
          }
        }
      ]
    },
    {
      "name": "Query",
      "item": [
        {
          "name": "LogQL++ query — GET /v1/query",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBaseUrl}}/v1/query?q=SELECT id, timestamp, service, level, message FROM logs WHERE level=\"error\" LIMIT 100",
              "host": ["{{apiBaseUrl}}"],
              "path": ["v1", "query"],
              "query": [{ "key": "q", "value": "SELECT id, timestamp, service, level, message FROM logs WHERE level=\"error\" LIMIT 100" }]
            },
            "description": "LogQL++ query. Tenant predicate is injected from identity. → {columns, count, rows}. Requires `logs:read`/`logs:query`."
          }
        },
        {
          "name": "Query as CSV — GET /v1/query?format=csv",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBaseUrl}}/v1/query?q=SEARCH \"timeout\" FROM logs LIMIT 50&format=csv",
              "host": ["{{apiBaseUrl}}"],
              "path": ["v1", "query"],
              "query": [
                { "key": "q", "value": "SEARCH \"timeout\" FROM logs LIMIT 50" },
                { "key": "format", "value": "csv" }
              ]
            },
            "description": "Same query surface; `format` may be `json` (default), `csv`, or `ndjson`."
          }
        },
        {
          "name": "Live tail (WebSocket) — GET /v1/query/tail",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Qeet-Api-Key", "value": "{{apiKey}}" }],
            "url": {
              "raw": "{{apiBaseUrl}}/v1/query/tail?q=TAIL FROM logs WHERE level=\"error\"",
              "host": ["{{apiBaseUrl}}"],
              "path": ["v1", "query", "tail"],
              "query": [{ "key": "q", "value": "TAIL FROM logs WHERE level=\"error\"" }]
            },
            "description": "NOTE: this endpoint upgrades to a WebSocket — use Postman's WebSocket request type (or a WS client) against this URL; newman cannot drive it. Supply a `TAIL FROM logs [WHERE …]` statement via `q`; each matching record arrives as a JSON text frame. Requires `logs:read`/`logs:query`."
          }
        },
        {
          "name": "Natural-language query — POST /v1/query/nl",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{apiBaseUrl}}/v1/query/nl", "host": ["{{apiBaseUrl}}"], "path": ["v1", "query", "nl"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"show me payment errors in the last hour\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Free text → LogQL++ via Claude. → {loqlpp, explanation}. Returns 501 if ANTHROPIC_API_KEY is unset. Requires `logs:read`."
          }
        },
        {
          "name": "Auth events — GET /v1/auth-events",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{apiBaseUrl}}/v1/auth-events", "host": ["{{apiBaseUrl}}"], "path": ["v1", "auth-events"] },
            "description": "Qeet ID auth-event stream for the tenant. Requires `logs:read`."
          }
        }
      ]
    },
    {
      "name": "PromQL",
      "item": [
        {
          "name": "Instant query — GET /api/v1/query",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBaseUrl}}/api/v1/query?query=rate(http_requests_total[5m])",
              "host": ["{{apiBaseUrl}}"],
              "path": ["api", "v1", "query"],
              "query": [{ "key": "query", "value": "rate(http_requests_total[5m])" }]
            },
            "description": "Prometheus-compatible instant query (Grafana Prometheus data source works unchanged). Requires `logs:read`."
          }
        },
        {
          "name": "Range query — GET /api/v1/query_range",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBaseUrl}}/api/v1/query_range?query=rate(http_requests_total[5m])&start=1705312800&end=1705316400&step=60",
              "host": ["{{apiBaseUrl}}"],
              "path": ["api", "v1", "query_range"],
              "query": [
                { "key": "query", "value": "rate(http_requests_total[5m])" },
                { "key": "start", "value": "1705312800" },
                { "key": "end", "value": "1705316400" },
                { "key": "step", "value": "60" }
              ]
            },
            "description": "Prometheus-compatible range query. Requires `logs:read`."
          }
        }
      ]
    },
    {
      "name": "Changes",
      "item": [
        {
          "name": "Record change event — POST /v1/changes",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{apiBaseUrl}}/v1/changes", "host": ["{{apiBaseUrl}}"], "path": ["v1", "changes"] },
            "body": {
