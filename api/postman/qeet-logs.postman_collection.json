              "raw": "{\n  \"kind\": \"deploy\",\n  \"service\": \"payments\",\n  \"environment\": \"production\",\n  \"git_sha\": \"a1b2c3d\",\n  \"deploy_id\": \"deploy-42\",\n  \"pr_number\": \"128\",\n  \"author\": \"jane\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Record a deploy/flag/config/rollback event for the timeline, RCA, and alert correlation. Requires `logs:ingest`."
