    {
      "name": "Admin — API Keys",
      "item": [
        {
          "name": "Create API key — POST /v1/admin/api-keys",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code < 300) {",
                  "  const b = pm.response.json();",
                  "  if (b.id) pm.collectionVariables.set('apiKeyId', b.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{apiBaseUrl}}/v1/admin/api-keys", "host": ["{{apiBaseUrl}}"], "path": ["v1", "admin", "api-keys"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"ci-ingest\",\n  \"scopes\": [\"logs:ingest\"]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Create a tenant API key. The full key value is returned once. Requires `logs:admin`."
          }
        },
        {
          "name": "List API keys — GET /v1/admin/api-keys",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{apiBaseUrl}}/v1/admin/api-keys", "host": ["{{apiBaseUrl}}"], "path": ["v1", "admin", "api-keys"] },
            "description": "List the tenant's API keys (key values redacted). Requires `logs:admin`."
          }
        },
        {
          "name": "Revoke API key — DELETE /v1/admin/api-keys/{id}",
