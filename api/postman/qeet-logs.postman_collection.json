    {
      "name": "Admin — Retention",
      "item": [
        {
          "name": "Get retention — GET /v1/admin/retention",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{apiBaseUrl}}/v1/admin/retention", "host": ["{{apiBaseUrl}}"], "path": ["v1", "admin", "retention"] },
            "description": "Get the tenant's retention config. Requires `logs:admin`."
          }
        },
        {
          "name": "Update retention — PUT /v1/admin/retention",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{apiBaseUrl}}/v1/admin/retention", "host": ["{{apiBaseUrl}}"], "path": ["v1", "admin", "retention"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"retention_days\": 30,\n  \"pii_mask_fields\": { \"email\": \"hash\" }\n}",
