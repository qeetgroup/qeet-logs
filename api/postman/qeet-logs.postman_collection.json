              "path": ["v1", "changes"],
              "query": [
                { "key": "service", "value": "payments" },
                { "key": "kind", "value": "deploy" },
                { "key": "limit", "value": "50" }
              ]
            },
            "description": "List change events. Requires `logs:read`."
          }
        }
      ]
    },
    {
      "name": "Investigation",
      "item": [
