          }
        },
        {
          "name": "Overlays — GET /v1/overlays",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{apiBaseUrl}}/v1/overlays", "host": ["{{apiBaseUrl}}"], "path": ["v1", "overlays"] },
            "description": "Dashboard correlation markers. Requires `logs:read`."
          }
        }
      ]
    },
    {
      "name": "Public / Shared",
      "item": [
        {
          "name": "Read shared dashboard — GET /shared/dashboards/{token}",
          "request": {
