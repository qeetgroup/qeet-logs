# Qeet Logs Console — environment variables
# Copy this file to `.env` (gitignored) and fill in real values for local dev.
# Schema: src/env.ts

# --- Client (exposed to the browser, must be prefixed with VITE_) ---

# Window title and visible app name.
VITE_APP_TITLE="Qeet Logs"

# Base URL of the qeet-logs query API (cmd/query). Default is :8100
# (see docker-compose / `make dev`). The live-tail WebSocket is derived
# from this host by swapping http(s) → ws(s).
VITE_API_URL="http://localhost:8100"


# --- Server (Node-only, never sent to the browser) ---

# Internal server URL (used by SSR / server functions).
# SERVER_URL="http://localhost:8100"
