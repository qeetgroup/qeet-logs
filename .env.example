# ── Query API server (Go) ───────────────────────────────────────────────────
HTTP_PORT=8100
ENV=development

# ── PostgreSQL (metadata: tenants, api keys, alert rules, audit) ─────────────
DATABASE_URL=postgres://qeet-logs:qeet-logs@localhost:5434/qeet-logs?sslmode=disable
MIGRATIONS_DIR=migrations

# ── ClickHouse (log storage) ─────────────────────────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=qeet_logs
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── NATS JetStream (ingestion bus) ───────────────────────────────────────────
NATS_URL=nats://localhost:4223

# ── Redis (live-tail pub/sub, query cache, rate limits) ──────────────────────
REDIS_URL=redis://localhost:6380

# ── Auth (Qeet ID OIDC) ──────────────────────────────────────────────────────
QEET_ID_ISSUER=https://api.id.qeet.in
COOKIE_DOMAIN=.logs.qeet.in

# ── Cold/archive tier object storage (S3 / MinIO) — Phase 2 ──────────────────
S3_BUCKET=qeet-logs
S3_ENDPOINT=http://localhost:9002
S3_REGION=ap-south-1

# ── Alert delivery via Qeet Notify — M6 ──────────────────────────────────────
QEET_NOTIFY_URL=https://api.notify.qeet.in
QEET_NOTIFY_API_KEY=

# ── Security: secrets envelope encryption (Phase 2) ──────────────────────────
# base64 of exactly 32 random bytes (`openssl rand -base64 32`). Encrypts secrets
# at rest (e.g. Slack bot tokens). Unset = dev plaintext passthrough.
QEET_LOGS_SECRETS_KEY=
# Per-tenant request cap (requests/minute) on the query surfaces; default 600.
RATE_LIMIT_PER_MINUTE=600

# ── AI Copilot — governed LLM, opt-in per tenant (Module 12 / P2-G11) ────────
# Unset = /v1/query/copilot* returns 501. Same key the NL-to-query path uses.
ANTHROPIC_API_KEY=

# ── Two-way ChatOps — Slack app (Module 19 / P2-G7) ──────────────────────────
# Unset = /v1/chatops/slack/* returns 501. Register a Slack app to enable.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_REDIRECT_URL=
QEET_LOGS_CONSOLE_URL=https://logs.qeet.in

# ── Cold-tier lifecycle mover (cmd/lifecycle, Module 6 / P2-G2) ──────────────
LIFECYCLE_INTERVAL=6h
